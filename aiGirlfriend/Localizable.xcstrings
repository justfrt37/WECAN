    "Acts like she's moved on… hasn't" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tut so, als hätte sie abgeschlossen… hat sie nicht"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actúa como si lo hubiera superado… pero no"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fait comme si elle avait tourné la page… mais non"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fa finta di essersela lasciata alle spalle… ma non è così"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Age como se tivesse superado… mas não superou"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unutmuş gibi davranır… ama unutmadı"
          }
        }
      }
    },
