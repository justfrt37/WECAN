    "Tell your story — how you met, memories you share, anything you want them to know…" : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erzähl eure Geschichte — wie ihr euch kennengelernt habt, gemeinsame Erinnerungen, alles, was sie wissen soll…"
